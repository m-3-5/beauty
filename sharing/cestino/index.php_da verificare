    <script>
    function toggleAI() { document.getElementById('ai-window').classList.toggle('d-none'); }
    async function sendToAI() {
        const input = document.getElementById('ai-input');
        const body = document.getElementById('ai-body');
        if (!input.value) return;
        const q = input.value;
        input.value = '';
        body.innerHTML += `<p class="text-end"><strong>Tu:</strong> ${q}</p>`;
        const loading = document.createElement('p');
        loading.className = "text-muted small";
        loading.innerText = "Sto pensando...";
        body.appendChild(loading);
        body.scrollTop = body.scrollHeight;

        try {
            const resp = await fetch('ai_handler.php', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({question: q})
            });
            const data = await resp.json();
            loading.remove();
            body.innerHTML += `<div class="bg-white p-2 rounded shadow-sm mb-2"><strong>AI:</strong> ${data.answer}</div>`;
        } catch (e) {
            loading.innerText = "Errore di connessione.";
        }
        body.scrollTop = body.scrollHeight;
    }
    </script>
