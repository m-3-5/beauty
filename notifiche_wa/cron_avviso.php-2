// Parametri SMTP Aruba Business (Dati forniti da Max)
$smtp_host = "ssl://out.postassl.it";
$smtp_port = 465;
$smtp_user = "info@beautyofimage.com";
$smtp_pass = "Beauty2023#"; 

// Dati Destinatario e WhatsApp
$telefono_beauty = "393487564418"; // Tuo numero per test
$apikey_beauty = "5458750"; 
$email_destinatario = "info@inm35.net";

// 1. INVIO WHATSAPP (Via cURL)
$testo_wa = "🚨 *PROMEMORIA BEAUTY OF IMAGE* 🚨\n\n";
$testo_wa .= "Mancano pochi giorni al 22 Marzo!\n";
$testo_wa .= "🔗 Gestione Inviti: https://beautyofimage.com/notifiche_wa/promemoria_massa.php";

$url = "https://api.callmebot.com/whatsapp.php?phone=$telefono_beauty&text=" . urlencode($testo_wa) . "&apikey=$apikey_beauty";
$ch = curl_init();
curl_setopt($ch, CURLOPT_URL, $url);
