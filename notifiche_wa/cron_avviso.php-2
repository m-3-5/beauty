// 2. INVIO EMAIL VIA SMTP (Per evitare lo Spam)
$subject = "Promemoria: Inviare inviti per l'inaugurazione";
$message = "Ciao, questo è il promemoria per l'evento in Corso Garibaldi, 7.\nAccedi qui: https://beautyofimage.com/notifiche_wa/promemoria_massa.php";

// Header per l'invio SMTP manuale
$header = "From: Beauty of Image <info@beautyofimage.com>\r\n";
$header .= "To: $email_destinatario\r\n";
$header .= "Subject: $subject\r\n";
$header .= "MIME-Version: 1.0\r\n";
$header .= "Content-Type: text/plain; charset=UTF-8\r\n";

// Connessione al server Aruba Business
$socket = fsockopen($smtp_host, $smtp_port, $errno, $errstr, 30);
if (!$socket) {
    die("Errore connessione SMTP: $errstr ($errno)");
}

// Dialogo con il server SMTP
fputs($socket, "EHLO " . $_SERVER['HTTP_HOST'] . "\r\n");
fputs($socket, "AUTH LOGIN\r\n");
fputs($socket, base64_encode($smtp_user) . "\r\n");
fputs($socket, base64_encode($smtp_pass) . "\r\n");
fputs($socket, "MAIL FROM: <$smtp_user>\r\n");
fputs($socket, "RCPT TO: <$email_destinatario>\r\n");
fputs($socket, "DATA\r\n");
fputs($socket, $header . "\r\n" . $message . "\r\n.\r\n");
fputs($socket, "QUIT\r\n");
fclose($socket);

echo "Notifiche inviate correttamente via WhatsApp e SMTP Certificato!";
